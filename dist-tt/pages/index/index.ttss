.index{background:linear-gradient(180deg,#00d4aa,#00a88a);box-sizing:border-box;color:#fff;min-height:100vh;overflow-y:auto;padding:64rpx 32rpx 120rpx}.index .hero{margin-bottom:80rpx;text-align:center}.index .hero .logo{display:block;font-size:120rpx;margin-bottom:24rpx}.index .hero .title{display:block;font-size:56rpx;font-weight:700;margin-bottom:16rpx}.index .hero .subtitle{display:block;font-size:28rpx;margin-bottom:24rpx;opacity:.9}.index .hero .tagline{display:block;font-size:32rpx;font-weight:600;opacity:.95}.index .valuation-teaser{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.2);border-radius:20rpx;margin-bottom:48rpx;padding:32rpx;text-align:center}.index .valuation-teaser .teaser-label{display:block;font-size:26rpx;margin-bottom:16rpx;opacity:.9}.index .valuation-teaser .teaser-gauge{align-items:center;display:flex;gap:12rpx;justify-content:center;margin-bottom:16rpx}.index .valuation-teaser .teaser-gauge .teaser-emoji{font-size:48rpx}.index .valuation-teaser .teaser-gauge .teaser-tier{font-size:36rpx;font-weight:700}.index .valuation-teaser .teaser-hint{display:block;font-size:24rpx;opacity:.85}.index .features{display:grid;gap:24rpx;grid-template-columns:repeat(3,1fr);margin-bottom:80rpx}.index .features .feature{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.15);border-radius:16rpx;padding:32rpx 16rpx;text-align:center}.index .features .feature .feature-icon{display:block;font-size:56rpx;margin-bottom:16rpx}.index .features .feature .feature-title{display:block;font-size:28rpx;font-weight:700;margin-bottom:8rpx}.index .features .feature .feature-desc{display:block;font-size:22rpx;opacity:.9}.index .cta{margin-bottom:80rpx;text-align:center}.index .cta .price-tag{display:block;font-size:40rpx;font-weight:700;margin-bottom:24rpx}.index .cta .start-button{background:#fff;border:none;border-radius:16rpx;box-shadow:0 8rpx 24rpx rgba(0,0,0,.2);color:#00d4aa;font-size:36rpx;font-weight:700;padding:32rpx 80rpx}.index .cta .start-button:active{transform:scale(.98)}.index .cta .pricing-link{margin-top:24rpx;text-align:center}.index .cta .pricing-link .price-tag{display:block;font-size:30rpx;font-weight:700;margin-bottom:8rpx}.index .cta .pricing-link .price-sub{display:block;font-size:24rpx;opacity:.85}.index .cta .disclaimer{display:block;font-size:24rpx;margin-top:24rpx;opacity:.9}.index .stats{backdrop-filter:blur(10rpx);background:hsla(0,0%,100%,.1);border-radius:24rpx;display:grid;gap:32rpx;grid-template-columns:repeat(3,1fr);padding:40rpx 24rpx}.index .stats .stat{text-align:center}.index .stats .stat .stat-number{display:block;font-size:48rpx;font-weight:700;margin-bottom:8rpx}.index .stats .stat .stat-label{display:block;font-size:24rpx;opacity:.9}