.ai-bubble{align-items:flex-start;display:flex;margin-bottom:32rpx;padding:0 16rpx}.ai-bubble--user{flex-direction:row;justify-content:flex-end}.ai-bubble--assistant{flex-direction:row;justify-content:flex-start}.ai-bubble__avatar{align-items:center;background:linear-gradient(135deg,#00d4aa,#00a88a);border-radius:50%;display:flex;flex-shrink:0;height:72rpx;justify-content:center;width:72rpx}.ai-bubble__avatar--user{background:linear-gradient(135deg,#667eea,#764ba2)}.ai-bubble__avatar-text{color:#fff;font-size:24rpx;font-weight:700}.ai-bubble__content-wrapper{display:flex;flex-direction:column;margin:0 16rpx;max-width:75%}.ai-bubble__content{border-radius:24rpx;padding:24rpx 28rpx;word-break:break-word}.ai-bubble__content--assistant{background:#fff;border-top-left-radius:8rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}.ai-bubble__content--user{background:linear-gradient(135deg,#00d4aa,#00b896);border-top-right-radius:8rpx}.ai-bubble__content--loading{align-items:center;display:flex;flex-direction:column;padding:28rpx 40rpx}.ai-bubble__text{display:block;font-size:28rpx;line-height:1.6}.ai-bubble__content--user .ai-bubble__text{color:#fff}.ai-bubble__content--assistant .ai-bubble__text{color:#333}.ai-bubble__text--empty{height:16rpx}.ai-bubble__time{color:#999;display:block;font-size:22rpx;margin-top:8rpx}.ai-bubble--user .ai-bubble__time{text-align:right}.ai-bubble--assistant .ai-bubble__time{text-align:left}.ai-bubble__loading-dots{align-items:center;display:flex;gap:12rpx;justify-content:center;margin-bottom:12rpx}.ai-bubble__dot{animation:dot-bounce 1.4s ease-in-out infinite both;background:#00d4aa;border-radius:50%;height:16rpx;width:16rpx}.ai-bubble__dot--1{animation-delay:-.32s}.ai-bubble__dot--2{animation-delay:-.16s}.ai-bubble__dot--3{animation-delay:0s}.ai-bubble__loading-text{color:#999;font-size:24rpx}@keyframes dot-bounce{0%,100%,80%{opacity:.4;transform:scale(.6)}40%{opacity:1;transform:scale(1)}}.ai-assistant{background:#f5f6f8;display:flex;flex-direction:column;height:100vh}.ai-assistant--loading{align-items:center;justify-content:center}.ai-assistant__loading-container{align-items:center;display:flex;flex-direction:column;gap:32rpx}.ai-assistant__loading-icon{align-items:center;display:flex;height:120rpx;justify-content:center;width:120rpx}.ai-assistant__loading-pulse{animation:pulse-glow 1.5s ease-in-out infinite;background:linear-gradient(135deg,#00d4aa,#00a88a);border-radius:50%;height:80rpx;width:80rpx}.ai-assistant__loading-text{color:#666;font-size:28rpx}.ai-assistant__header{align-items:center;background:#fff;border-bottom:1rpx solid #eee;display:flex;flex-shrink:0;justify-content:space-between;padding:24rpx 32rpx}.ai-assistant__header-info{display:flex;flex-direction:column;gap:6rpx}.ai-assistant__header-title{color:#1a1a1a;font-size:34rpx;font-weight:700}.ai-assistant__header-price{color:#666;font-size:24rpx}.ai-assistant__header-price .positive{color:#2e7d32}.ai-assistant__header-price .negative{color:#c62828}.ai-assistant__pro-badge{background:linear-gradient(135deg,#00d4aa,#00a88a);border-radius:20rpx;padding:8rpx 20rpx}.ai-assistant__pro-badge-text{color:#fff;font-size:22rpx;font-weight:700;letter-spacing:2rpx}.ai-assistant__upgrade-badge{background:linear-gradient(135deg,#667eea,#764ba2);border-radius:20rpx;padding:8rpx 20rpx}.ai-assistant__upgrade-badge-text{color:#fff;font-size:22rpx;font-weight:600}.ai-assistant__free-banner{background:linear-gradient(90deg,#667eea,#764ba2);flex-shrink:0;padding:16rpx 32rpx}.ai-assistant__free-banner-text{color:hsla(0,0%,100%,.95);display:block;font-size:24rpx;text-align:center}.ai-assistant__messages{flex:1;overflow:hidden}.ai-assistant__messages-inner{min-height:100%;padding:24rpx 0}.ai-assistant__scroll-anchor{height:1rpx}.ai-assistant__bottom{background:#fff;border-top:1rpx solid #eee;flex-shrink:0;padding-bottom:env(safe-area-inset-bottom)}.ai-assistant__quick-questions{padding:16rpx 0;white-space:nowrap}.ai-assistant__quick-questions-inner{display:inline-flex;gap:16rpx;padding:0 24rpx}.ai-assistant__chip{align-items:center;background:#f0faf7;border:2rpx solid #00d4aa;border-radius:32rpx;display:inline-flex;flex-shrink:0;padding:12rpx 24rpx;transition:all .2s ease}.ai-assistant__chip:active{background:#e0f5f0;transform:scale(.96)}.ai-assistant__chip--deep{background:linear-gradient(135deg,#e8f5e9,#f0faf7);border-color:#00d4aa}.ai-assistant__chip--deep .ai-assistant__chip-text{font-weight:600}.ai-assistant__chip--locked{background:#f5f0ff;border-color:#764ba2}.ai-assistant__chip--locked .ai-assistant__chip-text{color:#764ba2}.ai-assistant__chip--disabled{opacity:.5;pointer-events:none}.ai-assistant__chip-text{color:#00a88a;font-size:24rpx;white-space:nowrap}.ai-assistant__input-bar{align-items:center;display:flex;gap:16rpx;padding:16rpx 24rpx}.ai-assistant__input-wrapper{background:#f5f6f8;border:2rpx solid #eee;border-radius:40rpx;flex:1;padding:4rpx 8rpx;transition:border-color .2s ease}.ai-assistant__input-wrapper:focus-within{border-color:#00d4aa}.ai-assistant__input{font-size:28rpx;height:72rpx;padding:0 24rpx;width:100%}.ai-assistant__input-placeholder{color:#bbb;font-size:28rpx}.ai-assistant__send-btn{align-items:center;background:linear-gradient(135deg,#00d4aa,#00a88a);border-radius:36rpx;box-shadow:0 4rpx 12rpx rgba(0,212,170,.3);display:flex;flex-shrink:0;height:72rpx;justify-content:center;transition:all .2s ease;width:120rpx}.ai-assistant__send-btn:active{transform:scale(.96)}.ai-assistant__send-btn--disabled{background:#ccc;box-shadow:none;pointer-events:none}.ai-assistant__send-btn-text{color:#fff;font-size:28rpx;font-weight:600}.ai-assistant__safe-bottom{height:16rpx}@keyframes pulse-glow{0%{box-shadow:0 0 0 0 rgba(0,212,170,.4);transform:scale(1)}50%{box-shadow:0 0 0 20rpx rgba(0,212,170,0);transform:scale(1.05)}100%{box-shadow:0 0 0 0 rgba(0,212,170,0);transform:scale(1)}}