.dashboard{background:linear-gradient(180deg,#f8f9fa,#fff);box-sizing:border-box;min-height:100vh;padding:32rpx 32rpx 120rpx}.dashboard .header{margin-bottom:32rpx}.dashboard .header .header-top{align-items:flex-start;display:flex;justify-content:space-between}.dashboard .header .header-left{flex:1}.dashboard .header .title{color:#1a1a1a;display:block;font-size:48rpx;font-weight:700}.dashboard .header .subtitle{color:#666;display:block;font-size:28rpx;margin-top:8rpx}.dashboard .header .share-button{align-items:center;background:#f0f0f0;border-radius:20rpx;display:flex;flex-shrink:0;gap:8rpx;margin-top:8rpx;padding:12rpx 24rpx}.dashboard .header .share-button:active{background:#e0e0e0}.dashboard .header .share-button .share-icon{font-size:28rpx}.dashboard .header .share-button .share-text{color:#666;font-size:24rpx;font-weight:500}.dashboard .price-card{background:#fff;border-radius:24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.08);margin-bottom:32rpx;padding:40rpx}.dashboard .price-card .price-main{align-items:baseline;display:flex;gap:16rpx}.dashboard .price-card .price-main .price{color:#1a1a1a;font-size:64rpx;font-weight:700}.dashboard .price-card .price-main .change{align-items:center;border-radius:12rpx;display:flex;gap:8rpx;padding:8rpx 16rpx}.dashboard .price-card .price-main .change.positive{background:#e8f5e9;color:#2e7d32}.dashboard .price-card .price-main .change.negative{background:#ffebee;color:#c62828}.dashboard .price-card .price-main .change .change-percent,.dashboard .price-card .price-main .change .change-value{font-size:28rpx;font-weight:600}.dashboard .price-card .update-time{color:#999;display:block;font-size:24rpx;margin-top:16rpx}.dashboard .valuation-card{background:#fff;border-radius:24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.08);margin-bottom:32rpx;padding:40rpx}.dashboard .valuation-card .valuation-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:32rpx}.dashboard .valuation-card .valuation-header .valuation-title{color:#1a1a1a;font-size:36rpx;font-weight:700}.dashboard .valuation-card .gauge{display:flex;justify-content:center;margin:40rpx 0}.dashboard .valuation-card .gauge .gauge-circle{align-items:center;background:#fff;border:16rpx solid;border-radius:50%;display:flex;flex-direction:column;height:360rpx;justify-content:center;width:360rpx}.dashboard .valuation-card .gauge .gauge-circle .gauge-emoji{font-size:80rpx;margin-bottom:16rpx}.dashboard .valuation-card .gauge .gauge-circle .gauge-value{color:#1a1a1a;font-size:64rpx;font-weight:700}.dashboard .valuation-card .gauge .gauge-circle .gauge-label{color:#666;font-size:28rpx;margin-top:8rpx}.dashboard .valuation-card .valuation-status{border:2rpx solid;border-radius:16rpx;margin-top:32rpx;padding:24rpx;text-align:center}.dashboard .valuation-card .valuation-status .valuation-tier{font-size:36rpx;font-weight:700}.dashboard .stats-grid{display:grid;gap:24rpx;grid-template-columns:repeat(2,1fr);margin-bottom:32rpx}.dashboard .stats-grid .stat-item{background:#fff;border-radius:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);padding:32rpx}.dashboard .stats-grid .stat-item .stat-label{color:#666;display:block;font-size:24rpx;margin-bottom:12rpx}.dashboard .stats-grid .stat-item .stat-value{color:#1a1a1a;display:block;font-size:36rpx;font-weight:700}.dashboard .signal-card{background:#fff;border-radius:24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.08);margin-bottom:32rpx;padding:36rpx}.dashboard .signal-card .signal-header{margin-bottom:24rpx}.dashboard .signal-card .signal-header .signal-title{color:#1a1a1a;font-size:36rpx;font-weight:700}.dashboard .signal-card .signal-badge{align-items:center;border:2rpx solid;border-radius:16rpx;display:flex;gap:12rpx;justify-content:center;margin-bottom:24rpx;padding:24rpx}.dashboard .signal-card .signal-badge .signal-emoji{font-size:48rpx}.dashboard .signal-card .signal-badge .signal-label{font-size:40rpx;font-weight:700}.dashboard .signal-card .signal-reasons .signal-reason-item{align-items:flex-start;display:flex;gap:12rpx;margin-bottom:16rpx}.dashboard .signal-card .signal-reasons .signal-reason-item .signal-reason-bullet{color:#666;flex-shrink:0;font-size:28rpx;margin-top:2rpx}.dashboard .signal-card .signal-reasons .signal-reason-item .signal-reason-text{color:#444;font-size:26rpx;line-height:1.6}.dashboard .signal-card .signal-disclaimer{border-top:1rpx solid #eee;margin-top:20rpx;padding-top:16rpx}.dashboard .signal-card .signal-disclaimer .signal-disclaimer-text{color:#999;font-size:22rpx}.dashboard .upgrade-section{margin-bottom:32rpx}.dashboard .upgrade-section .upgrade-card{background:#fff;border-radius:20rpx;box-shadow:0 2rpx 16rpx rgba(0,0,0,.06);margin-bottom:24rpx;padding:36rpx;text-align:center}.dashboard .upgrade-section .upgrade-card .upgrade-icon{display:block;font-size:64rpx;margin-bottom:16rpx}.dashboard .upgrade-section .upgrade-card .upgrade-title{color:#1a1a1a;display:block;font-size:34rpx;font-weight:700;margin-bottom:12rpx}.dashboard .upgrade-section .upgrade-card .upgrade-desc{color:#666;display:block;font-size:26rpx;line-height:1.5;margin-bottom:24rpx}.dashboard .upgrade-section .upgrade-card .upgrade-button{background:linear-gradient(135deg,#00d4aa,#00a88a);border-radius:12rpx;box-shadow:0 4rpx 16rpx rgba(0,212,170,.3);display:inline-block;padding:20rpx 48rpx}.dashboard .upgrade-section .upgrade-card .upgrade-button .upgrade-button-text{color:#fff;font-size:28rpx;font-weight:600}.dashboard .upgrade-section .upgrade-cta{background:linear-gradient(135deg,#667eea,#764ba2);border-radius:20rpx;box-shadow:0 4rpx 20rpx rgba(102,126,234,.3);padding:36rpx;text-align:center}.dashboard .upgrade-section .upgrade-cta .upgrade-cta-text{color:#fff;display:block;font-size:34rpx;font-weight:700;margin-bottom:12rpx}.dashboard .upgrade-section .upgrade-cta .upgrade-cta-sub{color:hsla(0,0%,100%,.85);display:block;font-size:26rpx}.dashboard .pro-content{margin-bottom:32rpx}.dashboard .pro-content .pro-section{background:#fff;border-radius:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);margin-bottom:24rpx;padding:36rpx}.dashboard .pro-content .pro-section .pro-section-title{color:#1a1a1a;display:block;font-size:34rpx;font-weight:700;margin-bottom:24rpx}.dashboard .pro-content .history-chart{margin-bottom:24rpx}.dashboard .pro-content .history-chart .history-chart-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:20rpx}.dashboard .pro-content .history-chart .history-chart-header .history-chart-label{color:#1a1a1a;font-size:28rpx;font-weight:600}.dashboard .pro-content .history-chart .history-chart-header .history-chart-range{color:#999;font-size:22rpx}.dashboard .pro-content .history-chart .history-bar-chart .history-bar-row{align-items:center;display:flex;gap:12rpx;margin-bottom:12rpx}.dashboard .pro-content .history-chart .history-bar-chart .history-bar-row .history-bar-date{color:#666;flex-shrink:0;font-size:22rpx;width:120rpx}.dashboard .pro-content .history-chart .history-bar-chart .history-bar-row .history-bar-track{background:#f0f0f0;border-radius:12rpx;flex:1;height:24rpx;overflow:hidden}.dashboard .pro-content .history-chart .history-bar-chart .history-bar-row .history-bar-track .history-bar-fill{border-radius:12rpx;height:100%;transition:width .3s ease}.dashboard .pro-content .history-chart .history-bar-chart .history-bar-row .history-bar-value{color:#1a1a1a;flex-shrink:0;font-size:22rpx;font-weight:600;text-align:right;width:80rpx}.dashboard .pro-content .history-chart .history-bar-chart .history-bar-row .history-bar-trend{flex-shrink:0;font-size:24rpx;font-weight:700;text-align:center;width:32rpx}.dashboard .pro-content .history-chart .history-current{align-items:center;background:#f8f9fa;border-radius:12rpx;display:flex;gap:16rpx;justify-content:center;margin-top:20rpx;padding:20rpx}.dashboard .pro-content .history-chart .history-current .history-current-label{color:#666;font-size:26rpx}.dashboard .pro-content .history-chart .history-current .history-current-value{font-size:36rpx;font-weight:700}.dashboard .pro-content .history-chart .history-current .history-current-vs{color:#999;font-size:24rpx}.dashboard .pro-content .history-table .history-table-header{border-bottom:2rpx solid #eee;display:flex;margin-bottom:8rpx;padding:16rpx 0}.dashboard .pro-content .history-table .history-table-header .history-table-th{color:#999;flex:1;font-size:24rpx;font-weight:600;text-align:center}.dashboard .pro-content .history-table .history-table-row{border-bottom:1rpx solid #f5f5f5;display:flex;padding:14rpx 0}.dashboard .pro-content .history-table .history-table-row .history-table-td{color:#444;flex:1;font-size:24rpx;text-align:center}.dashboard .pro-content .ai-placeholder,.dashboard .pro-content .alert-placeholder,.dashboard .pro-content .chart-placeholder{background:#f8f9fa;border-radius:12rpx;padding:40rpx 32rpx;text-align:center}.dashboard .pro-content .ai-placeholder .ai-placeholder-text,.dashboard .pro-content .ai-placeholder .alert-placeholder-text,.dashboard .pro-content .ai-placeholder .chart-placeholder-text,.dashboard .pro-content .alert-placeholder .ai-placeholder-text,.dashboard .pro-content .alert-placeholder .alert-placeholder-text,.dashboard .pro-content .alert-placeholder .chart-placeholder-text,.dashboard .pro-content .chart-placeholder .ai-placeholder-text,.dashboard .pro-content .chart-placeholder .alert-placeholder-text,.dashboard .pro-content .chart-placeholder .chart-placeholder-text{color:#666;font-size:28rpx;line-height:1.6}.dashboard .info-section{background:#f0f9ff;border-radius:16rpx;margin-bottom:32rpx;padding:32rpx}.dashboard .info-section .info-title{color:#1a1a1a;display:block;font-size:32rpx;font-weight:700;margin-bottom:16rpx}.dashboard .info-section .info-text{color:#555;display:block;font-size:28rpx;line-height:1.6;margin-bottom:12rpx}.dashboard .disclaimer{background:#fff3cd;border-left:6rpx solid #ff9800;border-radius:12rpx;padding:24rpx}.dashboard .disclaimer .disclaimer-text{color:#856404;font-size:24rpx;line-height:1.5}.dashboard.loading{display:flex;flex-direction:column;gap:32rpx;padding:32rpx}.dashboard.loading .skeleton-card{background:#fff;border-radius:24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.08);padding:40rpx}.dashboard.loading .skeleton-card .skeleton-line{animation:skeleton-pulse 1.5s infinite;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;border-radius:8rpx;height:32rpx;margin-bottom:16rpx}.dashboard.loading .skeleton-card .skeleton-line.skeleton-wide{width:80%}.dashboard.loading .skeleton-card .skeleton-line.skeleton-narrow{width:50%}.dashboard.loading .skeleton-card .skeleton-circle{animation:skeleton-pulse 1.5s infinite;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;border-radius:50%;height:200rpx;margin:24rpx auto;width:200rpx}.dashboard.error{align-items:center;color:#666;display:flex;font-size:32rpx;justify-content:center;min-height:100vh}@keyframes skeleton-pulse{0%{background-position:200% 0}100%{background-position:-200% 0}}