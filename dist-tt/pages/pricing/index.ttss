.pricing-toggle{align-items:center;display:flex;gap:20rpx;justify-content:center;margin:32rpx 0 48rpx}.pricing-toggle .toggle-label{color:#999;font-size:30rpx;font-weight:500;transition:color .3s ease}.pricing-toggle .toggle-label.active{color:#1a1a1a;font-weight:700}.pricing-toggle .toggle-annual-wrapper{align-items:center;display:flex;gap:12rpx}.pricing-toggle .toggle-switch{cursor:pointer;height:52rpx;width:100rpx}.pricing-toggle .toggle-switch .toggle-track{background:#ccc;border-radius:26rpx;height:100%;position:relative;transition:background .3s ease;width:100%}.pricing-toggle .toggle-switch .toggle-track.annual{background:linear-gradient(135deg,#00d4aa,#00a88a)}.pricing-toggle .toggle-switch .toggle-track.annual .toggle-thumb{transform:translateX(48rpx)}.pricing-toggle .toggle-switch .toggle-track .toggle-thumb{background:#fff;border-radius:50%;box-shadow:0 2rpx 8rpx rgba(0,0,0,.15);height:44rpx;left:4rpx;position:absolute;top:4rpx;transition:transform .3s ease;width:44rpx}.pricing-toggle .savings-badge{background:linear-gradient(135deg,#ff6b6b,#ee5a24);border-radius:16rpx;padding:6rpx 16rpx}.pricing-toggle .savings-badge .savings-text{color:#fff;font-size:22rpx;font-weight:700}.pricing{background:linear-gradient(180deg,#f0f9ff,#fff);min-height:100vh;padding:32rpx}.pricing .hero{margin-bottom:24rpx;text-align:center}.pricing .hero .hero-title{color:#1a1a1a;display:block;font-size:56rpx;font-weight:700;margin-bottom:16rpx}.pricing .hero .hero-subtitle{color:#666;display:block;font-size:30rpx}.pricing .pricing-cards{margin-bottom:32rpx}.pricing .pricing-card{background:#fff;border:3rpx solid transparent;border-radius:32rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.06);margin-bottom:32rpx;padding:48rpx;position:relative;transition:border-color .3s ease,box-shadow .3s ease}.pricing .pricing-card.selected{border-color:#00d4aa}.pricing .pricing-card.recommended{border-color:#00d4aa;box-shadow:0 8rpx 32rpx rgba(0,212,170,.2)}.pricing .pricing-card.recommended .price-display .currency,.pricing .pricing-card.recommended .price-display .price{color:#00a88a}.pricing .pricing-card .badge{background:linear-gradient(135deg,#ff6b6b,#ee5a24);border-radius:24rpx;box-shadow:0 4rpx 12rpx hsla(0,100%,71%,.4);padding:12rpx 32rpx;position:absolute;right:40rpx;top:-16rpx}.pricing .pricing-card .badge .badge-text{color:#fff;font-size:24rpx;font-weight:700}.pricing .pricing-card .card-header{margin-bottom:24rpx}.pricing .pricing-card .card-header .plan-name{color:#1a1a1a;display:block;font-size:40rpx;font-weight:700;margin-bottom:8rpx}.pricing .pricing-card .card-header .plan-scope{color:#888;display:block;font-size:26rpx}.pricing .pricing-card .price-display{align-items:baseline;display:flex;justify-content:center;margin:24rpx 0 12rpx}.pricing .pricing-card .price-display .currency{color:#00d4aa;font-size:48rpx;font-weight:700}.pricing .pricing-card .price-display .price{color:#00d4aa;font-size:100rpx;font-weight:700;line-height:1}.pricing .pricing-card .price-display .period{color:#666;font-size:32rpx;margin-left:8rpx}.pricing .pricing-card .annual-total{margin-bottom:8rpx;text-align:center}.pricing .pricing-card .annual-total .annual-total-text{color:#ee5a24;font-size:26rpx;font-weight:600}.pricing .pricing-card .price-daily{color:#999;display:block;font-size:26rpx;margin-bottom:32rpx;text-align:center}.pricing .pricing-card .features-list{margin-bottom:40rpx}.pricing .pricing-card .features-list .feature-item{align-items:center;border-bottom:1rpx solid #f0f0f0;display:flex;gap:16rpx;padding:18rpx 0}.pricing .pricing-card .features-list .feature-item:last-child{border-bottom:none}.pricing .pricing-card .features-list .feature-item.highlight .feature-text{color:#00a88a;font-weight:600}.pricing .pricing-card .features-list .feature-item .feature-icon{font-size:32rpx}.pricing .pricing-card .features-list .feature-item .feature-text{color:#333;font-size:30rpx}.pricing .pricing-card .subscribe-button{background:linear-gradient(135deg,#00d4aa,#00a88a);border:none;border-radius:16rpx;box-shadow:0 6rpx 20rpx rgba(0,212,170,.3);color:#fff;font-size:34rpx;font-weight:700;padding:28rpx;width:100%}.pricing .pricing-card .subscribe-button.pro{background:linear-gradient(135deg,#667eea,#764ba2);box-shadow:0 6rpx 20rpx rgba(102,126,234,.3)}.pricing .pricing-card .subscribe-button:active{transform:scale(.98)}.pricing .annual-highlight{background:linear-gradient(135deg,#fff8e1,#ffecb3);border:2rpx solid #ffc107;border-radius:16rpx;margin-bottom:48rpx;padding:24rpx 32rpx;text-align:center}.pricing .annual-highlight .annual-highlight-text{color:#f57f17;font-size:28rpx;font-weight:600}.pricing .social-proof{background:#fff;border-radius:24rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.06);margin-bottom:48rpx;padding:40rpx}.pricing .social-proof .proof-title{color:#1a1a1a;display:block;font-size:32rpx;font-weight:700;margin-bottom:32rpx;text-align:center}.pricing .social-proof .testimonials .testimonial{background:#f8f9fa;border-radius:16rpx;margin-bottom:24rpx;padding:32rpx}.pricing .social-proof .testimonials .testimonial:last-child{margin-bottom:0}.pricing .social-proof .testimonials .testimonial .testimonial-text{color:#333;display:block;font-size:28rpx;line-height:1.6;margin-bottom:16rpx}.pricing .social-proof .testimonials .testimonial .testimonial-author{color:#999;display:block;font-size:24rpx}.pricing .value-section{margin-bottom:48rpx}.pricing .value-section .value-title{color:#1a1a1a;display:block;font-size:48rpx;font-weight:700;margin-bottom:40rpx;text-align:center}.pricing .value-section .value-item{align-items:flex-start;background:#fff;border-radius:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);display:flex;gap:24rpx;margin-bottom:24rpx;padding:32rpx}.pricing .value-section .value-item .value-icon{font-size:56rpx}.pricing .value-section .value-item .value-content{flex:1}.pricing .value-section .value-item .value-content .value-heading{color:#1a1a1a;display:block;font-size:32rpx;font-weight:700;margin-bottom:12rpx}.pricing .value-section .value-item .value-content .value-text{color:#666;display:block;font-size:28rpx;line-height:1.5}.pricing .faq-section{margin-bottom:48rpx}.pricing .faq-section .faq-title{color:#1a1a1a;display:block;font-size:48rpx;font-weight:700;margin-bottom:40rpx;text-align:center}.pricing .faq-section .faq-item{background:#fff;border-radius:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);margin-bottom:24rpx;padding:32rpx}.pricing .faq-section .faq-item .faq-question{color:#1a1a1a;display:block;font-size:30rpx;font-weight:700;margin-bottom:12rpx}.pricing .faq-section .faq-item .faq-answer{color:#666;display:block;font-size:28rpx;line-height:1.6}.pricing .disclaimer{background:#fff3cd;border-left:6rpx solid #ff9800;border-radius:12rpx;padding:24rpx}.pricing .disclaimer .disclaimer-text{color:#856404;font-size:24rpx;line-height:1.5}