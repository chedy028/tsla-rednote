.custom-tabbar{align-items:center;background:#fff;border-top:1rpx solid #e5e5e5;bottom:0;display:flex;height:100rpx;justify-content:space-around;left:0;padding-bottom:env(safe-area-inset-bottom,0);position:fixed;right:0;z-index:999}.custom-tabbar .tabbar-item{align-items:center;cursor:pointer;display:flex;flex:1;flex-direction:column;gap:4rpx;justify-content:center;-webkit-tap-highlight-color:transparent}.custom-tabbar .tabbar-item.active .tabbar-text{color:#00d4aa;font-weight:600}.custom-tabbar .tabbar-item .tabbar-icon{display:block;font-size:40rpx;line-height:1}.custom-tabbar .tabbar-item .tabbar-text{color:#999;display:block;font-size:20rpx}