# ============================================================================
# TSLA Red Note - Supabase Edge Functions Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL (e.g., https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key — has full access, bypasses RLS. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=

# ─── WeChat Mini Program ─────────────────────────────────────────────────────
# Found in the WeChat Mini Program admin console (mp.weixin.qq.com)
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ─── WeChat Pay V3 ───────────────────────────────────────────────────────────
# Merchant ID from WeChat Pay merchant platform (pay.weixin.qq.com)
WECHAT_PAY_MCH_ID=

# API v3 key — set in the merchant platform under API Security
WECHAT_PAY_API_KEY=

# Certificate serial number — from the merchant platform certificate management
WECHAT_PAY_SERIAL_NO=

# RSA private key (PKCS#8 PEM format) — the full key including BEGIN/END lines.
# For Edge Functions, set this as a single-line string with literal \n for newlines,
# or use Supabase's secret management which handles multiline values.
WECHAT_PAY_PRIVATE_KEY=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Secret used to sign session JWT tokens. If not set, falls back to SUPABASE_SERVICE_ROLE_KEY.
# Recommended: generate a strong random string (e.g., openssl rand -hex 32)
JWT_SECRET=

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
# API key for OpenAI (or compatible API like Azure OpenAI, Deepseek, etc.)
OPENAI_API_KEY=

# (Optional) Override the base URL for OpenAI-compatible APIs
# Default: https://api.openai.com/v1
# OPENAI_BASE_URL=

# (Optional) Override the model name
# Default: gpt-4o-mini
# AI_MODEL=

# (Optional) Alternative env var name for the AI API key
# AI_API_KEY=
